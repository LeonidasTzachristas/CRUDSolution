@if (ViewBag.CurrentSortBy == ViewBag.ColumnName && 
     ViewBag.CurrentSortOrder == SortOrderEnum.Ascending)
{
    <th><a href="~/persons/index?searchBy=@(ViewBag.CurrentSearchBy)&searchString=@(ViewBag.CurrentSearchString)&sortBy=@(ViewBag.ColumnName)&sortOrder=@(SortOrderEnum.Descending)">
        @ViewBag.DisplayName<img alt="Up" src="~/arrowDown.svg" width="14"/>
    </a></th>
}
else if (ViewBag.CurrentSortBy == @ViewBag.ColumnName && 
         ViewBag.CurrentSortOrder == SortOrderEnum.Descending)
{
    <th><a href="~/persons/index?searchBy=@(ViewBag.CurrentSearchBy)&searchString=@(ViewBag.CurrentSearchString)&sortBy=@(ViewBag.ColumnName)&sortOrder=@(SortOrderEnum.Ascending)">
        @ViewBag.DisplayName<img alt="Up" src="~/arrowUp.svg" width="14"/>
    </a></th>
}
else
{
    <th><a href="~/persons/index?searchBy=@(ViewBag.CurrentSearchBy)&searchString=@(ViewBag.CurrentSearchString)&sortBy=@(ViewBag.ColumnName)&sortOrder=@(SortOrderEnum.Ascending)">
        @ViewBag.DisplayName<img alt="Up" src="~/dots.svg" width="14"/>
    </a></th>
}